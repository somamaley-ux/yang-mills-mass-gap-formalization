structure YMNamedCompanionTheoremReflection
    (RC : YMConstructiveRoute)
    (RD : YMVacuumGapRoute)
    (RE : YMEndpointCore) where
  companion1_reflection : ym_companion1_named_theorem_reflection RD
  companion2_reflection : ym_companion2_named_theorem_reflection RC
  companion3_reflection : ym_companion3_named_theorem_reflection RE

def YangMillsNamedCompanionTheoremReflectionData
  (RC : YMConstructiveRoute)
  (RD : YMVacuumGapRoute)
  (RE : YMEndpointCore)
  (hpartC : ym_paper_partC_statement RC)
  (hpartD : ym_paper_partD_statement RD)
  (hendpoint : ym_paper_endpoint_statement RE) :
  YMNamedCompanionTheoremReflection RC RD RE := by
  exact
    { companion1_reflection :=
        And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
          And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
            And.intro rfl <| And.intro rfl <| And.intro rfl <|
              And.intro rfl <| And.intro rfl <| And.intro rfl <|
                And.intro rfl <| And.intro rfl <| And.intro rfl hpartD
      companion2_reflection :=
        And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
          And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
            And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
              And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
                And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
                  And.intro rfl <| And.intro rfl <| And.intro rfl <|
                    And.intro rfl hpartC
      companion3_reflection :=
        And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
          And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
            And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
              And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl <|
                And.intro rfl <| And.intro rfl <| And.intro rfl <| And.intro rfl
                  hendpoint }

theorem YangMillsNamedCompanionTheoremReflectionExportStatement
  (RC : YMConstructiveRoute)
  (RD : YMVacuumGapRoute)
  (RE : YMEndpointCore)
  (hpartC : ym_paper_partC_statement RC)
  (hpartD : ym_paper_partD_statement RD)
  (hendpoint : ym_paper_endpoint_statement RE) :
  Nonempty (YMNamedCompanionTheoremReflection RC RD RE) /\
  ym_companion1_named_theorem_reflection RD /\
  ym_companion2_named_theorem_reflection RC /\
  ym_companion3_named_theorem_reflection RE := by
  let A :=
    YangMillsNamedCompanionTheoremReflectionData
      RC RD RE hpartC hpartD hendpoint
  exact And.intro ⟨A⟩ <|
    And.intro A.companion1_reflection <|
      And.intro A.companion2_reflection A.companion3_reflection

end MaleyLean
